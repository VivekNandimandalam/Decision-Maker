# Production Environment Variables Template
# Copy to .env and fill in actual values

# ============ DJANGO SETTINGS ============
DEBUG=False
DJANGO_SECRET_KEY=your-random-secret-key-min-50-chars
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,polling-app-backend.elasticbeanstalk.com

# ============ DATABASE ============
DATABASE_URL=postgresql://admin:PASSWORD@polling-app-db.xxxxx.rds.amazonaws.com:5432/polling_db

# ============ CORS & FRONTEND ============
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ============ SECURITY ============
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# ============ AWS S3 (STATIC FILES) ============
USE_S3=True
AWS_STORAGE_BUCKET_NAME=polling-app-static-{account-id}
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN={bucket-name}.s3.amazonaws.com
AWS_CLOUDFRONT_DOMAIN=d{distribution-id}.cloudfront.net
AWS_S3_SIGNATURE_VERSION=s3v4

# ============ AWS CREDENTIALS ============
# Ideally use IAM Role instead of credentials
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# ============ LOGGING ============
LOG_LEVEL=INFO
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx  # Optional: Error tracking

# ============ RATE LIMITING ============
RATELIMIT_POLL_CREATE=20/m
RATELIMIT_VOTE=30/m

# ============ EMAIL (FOR NOTIFICATIONS) ============
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ============ REDIS (OPTIONAL - FOR CACHING) ============
REDIS_URL=redis://redis-cache.xxxxx.ng.0001.use1.cache.amazonaws.com:6379/0

# ============ MONITORING ============
DATADOG_API_KEY=your-datadog-api-key  # Optional: APM monitoring
