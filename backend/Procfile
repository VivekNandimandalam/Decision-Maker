# Set these via AWS Console → Configuration → Environment properties
# Or use: eb setenv VARIABLE=value
#
# Required variables:
# - DJANGO_SECRET_KEY=<generate-random-key>
# - DATABASE_URL=postgresql://admin:password@rds-endpoint/polling_db
# - CORS_ALLOWED_ORIGINS=https://yourdomain.com
# - ALLOWED_HOSTS=yourdomain.com,polling-app.elasticbeanstalk.com
# - DEBUG=False
#
# Optional S3 variables:
# - USE_S3=True
# - AWS_STORAGE_BUCKET_NAME=polling-app-static
# - AWS_CLOUDFRONT_DOMAIN=d12345.cloudfront.net
# - AWS_S3_REGION_NAME=us-east-1